<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- 层级地图专用 Biome（无动物/植物/天气） -->
  <BiomeDef>
    <defName>MLF_LevelBiome</defName>
    <label>层级地图生态</label>
    <description>层级地图专用的室内生态环境。</description>
    <generatesNaturally>false</generatesNaturally>
    <animalDensity>0</animalDensity>
    <plantDensity>0</plantDensity>
    <wildAnimalsCanWanderInto>false</wildAnimalsCanWanderInto>
    <diseaseMtbDays>999</diseaseMtbDays>
    <baseWeatherCommonalities>
      <Clear>1</Clear>
    </baseWeatherCommonalities>
  </BiomeDef>

  <!-- 无地板地形（露天/空气） - 上层没有地板的格子 -->
  <TerrainDef>
    <defName>MLF_OpenAir</defName>
    <label>露天</label>
    <description>这里没有地板——下方是露天空间。</description>
    <texturePath>Terrain/Surfaces/GenericFloorTile</texturePath>
    <edgeType>Hard</edgeType>
    <renderPrecedence>1</renderPrecedence>
    <passability>Impassable</passability>
    <layerable>false</layerable>
    <scatterType>None</scatterType>
    <fertility>0</fertility>
    <color>(0.15, 0.15, 0.15)</color>
    <affordances>
      <li>Light</li>
    </affordances>
  </TerrainDef>

  <!-- 楼层基底地形 - 可用区域的底层，支持所有地板建造 -->
  <TerrainDef>
    <defName>MLF_LevelBase</defName>
    <label>楼层基底</label>
    <description>楼层的结构基底，可在上面铺设任意地板。</description>
    <texturePath>Terrain/Surfaces/GenericFloorTile</texturePath>
    <edgeType>Hard</edgeType>
    <renderPrecedence>399</renderPrecedence>
    <passability>Standable</passability>
    <layerable>false</layerable>
    <scatterType>None</scatterType>
    <fertility>0</fertility>
    <color>(0.45, 0.45, 0.45)</color>
    <affordances>
      <li>Light</li>
      <li>Medium</li>
      <li>Heavy</li>
      <li>Walkable</li>
      <li>SmoothableStone</li>
    </affordances>
  </TerrainDef>

  <!-- GenStep 定义 -->
  <GenStepDef>
    <defName>MLF_LevelInterior</defName>
    <order>10</order>
    <genStep Class="MapLevelFramework.GenStep_LevelInterior"/>
  </GenStepDef>

  <!-- 层级子地图的 MapGeneratorDef -->
  <MapGeneratorDef>
    <defName>MLF_LevelMapGenerator</defName>
    <defaultUnderGridTerrain>MLF_LevelBase</defaultUnderGridTerrain>
    <pocketMapProperties>
      <biome>MLF_LevelBiome</biome>
      <temperature>21</temperature>
    </pocketMapProperties>
    <genSteps>
      <li>MLF_LevelInterior</li>
    </genSteps>
  </MapGeneratorDef>

  <!-- 层级子地图的 WorldObjectDef -->
  <WorldObjectDef>
    <defName>MLF_LevelMap</defName>
    <label>层级地图</label>
    <worldObjectClass>MapLevelFramework.LevelMapParent</worldObjectClass>
    <mapGenerator>MLF_LevelMapGenerator</mapGenerator>
    <selectable>false</selectable>
    <neverMultiSelect>true</neverMultiSelect>
    <saved>true</saved>
  </WorldObjectDef>

  <!-- ========== 地下层 ========== -->

  <!-- 地下泥地 - 挖掘岩石后露出的地面 -->
  <TerrainDef>
    <defName>MLF_DirtFloor</defName>
    <label>泥地</label>
    <description>挖掘岩石后露出的泥土地面。</description>
    <texturePath>Terrain/Surfaces/RoughStone</texturePath>
    <edgeType>Hard</edgeType>
    <renderPrecedence>399</renderPrecedence>
    <passability>Standable</passability>
    <layerable>false</layerable>
    <scatterType>Rocky</scatterType>
    <fertility>0</fertility>
    <color>(0.35, 0.30, 0.25)</color>
    <affordances>
      <li>Light</li>
      <li>Medium</li>
      <li>Heavy</li>
      <li>Walkable</li>
      <li>SmoothableStone</li>
    </affordances>
  </TerrainDef>

  <!-- 地下层 GenStep -->
  <GenStepDef>
    <defName>MLF_UndergroundInterior</defName>
    <order>10</order>
    <genStep Class="MapLevelFramework.GenStep_UndergroundInterior"/>
  </GenStepDef>

  <!-- 地下层 MapGenerator -->
  <MapGeneratorDef>
    <defName>MLF_UndergroundMapGenerator</defName>
    <defaultUnderGridTerrain>MLF_LevelBase</defaultUnderGridTerrain>
    <pocketMapProperties>
      <biome>MLF_LevelBiome</biome>
      <temperature>15</temperature>
    </pocketMapProperties>
    <genSteps>
      <li>MLF_UndergroundInterior</li>
    </genSteps>
  </MapGeneratorDef>

  <!-- ========== Job ========== -->

  <JobDef>
    <defName>MLF_UseStairs</defName>
    <driverClass>MapLevelFramework.JobDriver_UseStairs</driverClass>
    <reportString>使用楼层传送器。</reportString>
    <allowOpportunisticPrefix>false</allowOpportunisticPrefix>
  </JobDef>

  <JobDef>
    <defName>MLF_JumpDown</defName>
    <driverClass>MapLevelFramework.JobDriver_JumpDown</driverClass>
    <reportString>跳下楼。</reportString>
    <allowOpportunisticPrefix>false</allowOpportunisticPrefix>
    <suspendable>false</suspendable>
  </JobDef>

  <JobDef>
    <defName>MLF_HaulToStairs</defName>
    <driverClass>MapLevelFramework.JobDriver_HaulToStairs</driverClass>
    <reportString>搬运材料到楼梯。</reportString>
    <allowOpportunisticPrefix>false</allowOpportunisticPrefix>
  </JobDef>

  <JobDef>
    <defName>MLF_HaulAcrossLevel</defName>
    <driverClass>MapLevelFramework.JobDriver_HaulAcrossLevel</driverClass>
    <reportString>搬运物品到其他楼层。</reportString>
    <allowOpportunisticPrefix>false</allowOpportunisticPrefix>
  </JobDef>

  <JobDef>
    <defName>MLF_DeliverResourcesCrossFloor</defName>
    <driverClass>MapLevelFramework.JobDriver_DeliverResourcesCrossFloor</driverClass>
    <reportString>搬运建材到其他楼层的蓝图。</reportString>
    <allowOpportunisticPrefix>false</allowOpportunisticPrefix>
  </JobDef>

  <!-- ========== 精神崩溃：跳楼 ========== -->

  <MentalStateDef>
    <defName>MLF_JumpOff</defName>
    <label>试图跳楼</label>
    <stateClass>MapLevelFramework.MentalState_JumpOff</stateClass>
    <workerClass>MapLevelFramework.MentalStateWorker_JumpOff</workerClass>
    <category>Misc</category>
    <colonistsOnly>true</colonistsOnly>
    <nameColor>(0.9, 0.3, 0.3)</nameColor>
    <minTicksBeforeRecovery>500</minTicksBeforeRecovery>
    <maxTicksBeforeRecovery>5000</maxTicksBeforeRecovery>
    <recoveryMtbDays>0.05</recoveryMtbDays>
    <recoverFromSleep>true</recoverFromSleep>
    <recoverFromDowned>true</recoverFromDowned>
    <moodRecoveryThought>Catharsis</moodRecoveryThought>
    <blockNormalThoughts>true</blockNormalThoughts>
    <beginLetterLabel>试图跳楼</beginLetterLabel>
    <beginLetter>{0} 精神崩溃，正冲向楼层边缘试图跳下去！</beginLetter>
    <beginLetterDef>ThreatBig</beginLetterDef>
    <recoveryMessage>{0} 不再试图跳楼了。</recoveryMessage>
    <baseInspectLine>精神状态：试图跳楼</baseInspectLine>
  </MentalStateDef>

  <MentalBreakDef>
    <defName>MLF_JumpOff</defName>
    <mentalState>MLF_JumpOff</mentalState>
    <baseCommonality>0.15</baseCommonality>
    <intensity>Extreme</intensity>
  </MentalBreakDef>

  <!-- 跨层搬运 WorkGiver -->
  <WorkGiverDef>
    <defName>MLF_HaulAcrossLevel</defName>
    <label>跨层搬运</label>
    <giverClass>MapLevelFramework.WorkGiver_HaulAcrossLevel</giverClass>
    <workType>Hauling</workType>
    <priorityInType>70</priorityInType>
    <verb>搬运到其他楼层</verb>
    <gerund>搬运物品到其他楼层</gerund>
  </WorkGiverDef>

  <!-- ========== 建筑 ========== -->

  <!-- 楼梯（上楼） -->
  <ThingDef ParentName="BuildingBase">
    <defName>MLF_Stairs</defName>
    <label>楼层传送器（上）</label>
    <description>连接地面层和上层的楼层传送器。在有屋顶的房间内建造，即可创建二楼。\n\n作者累了，采用偷懒方案：任意传送器之间可以互相传送，无需在同一位置。\n不要问我为什么楼梯可以存电，问就是超凡科技。</description>
    <thingClass>MapLevelFramework.Building_Stairs</thingClass>
    <graphicData>
      <texPath>楼梯</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1,1)</drawSize>
    </graphicData>
    <size>(1,1)</size>
    <rotatable>false</rotatable>
    <altitudeLayer>Building</altitudeLayer>
    <passability>Standable</passability>
    <pathCost>0</pathCost>
    <blockWind>false</blockWind>
    <castEdgeShadows>false</castEdgeShadows>
    <fillPercent>0.15</fillPercent>
    <statBases>
      <MaxHitPoints>200</MaxHitPoints>
      <WorkToBuild>1000</WorkToBuild>
      <Flammability>0.5</Flammability>
    </statBases>
    <costList>
      <WoodLog>30</WoodLog>
    </costList>
    <designationCategory>Structure</designationCategory>
    <building>
      <isInert>true</isInert>
    </building>
    <comps>
      <li Class="CompProperties_Battery">
        <compClass>MapLevelFramework.CompPowerBatteryRelay</compClass>
        <storedEnergyMax>99999999</storedEnergyMax>
        <efficiency>1.0</efficiency>
        <transmitsPower>true</transmitsPower>
      </li>
    </comps>
  </ThingDef>

  <!-- 楼梯（下楼） -->
  <ThingDef ParentName="BuildingBase">
    <defName>MLF_StairsDown</defName>
    <label>楼层传送器（下）</label>
    <description>通往地下层的楼层传送器。建造后即可开辟地下空间。\n\n作者累了，采用偷懒方案：任意传送器之间可以互相传送，无需在同一位置。\n不要问我为什么楼梯可以存电，问就是超凡科技。</description>
    <thingClass>MapLevelFramework.Building_Stairs</thingClass>
    <graphicData>
      <texPath>楼梯</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1,1)</drawSize>
    </graphicData>
    <size>(1,1)</size>
    <rotatable>false</rotatable>
    <altitudeLayer>Building</altitudeLayer>
    <passability>Standable</passability>
    <pathCost>0</pathCost>
    <blockWind>false</blockWind>
    <castEdgeShadows>false</castEdgeShadows>
    <fillPercent>0.15</fillPercent>
    <statBases>
      <MaxHitPoints>200</MaxHitPoints>
      <WorkToBuild>1000</WorkToBuild>
      <Flammability>0.5</Flammability>
    </statBases>
    <costList>
      <WoodLog>30</WoodLog>
    </costList>
    <designationCategory>Structure</designationCategory>
    <building>
      <isInert>true</isInert>
    </building>
    <comps>
      <li Class="CompProperties_Battery">
        <compClass>MapLevelFramework.CompPowerBatteryRelay</compClass>
        <storedEnergyMax>99999999</storedEnergyMax>
        <efficiency>1.0</efficiency>
        <transmitsPower>true</transmitsPower>
      </li>
    </comps>
    <modExtensions>
      <li Class="MapLevelFramework.StairsExtension">
        <goesDown>true</goesDown>
      </li>
    </modExtensions>
  </ThingDef>

</Defs>
